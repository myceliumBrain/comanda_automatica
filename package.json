{
  "name": "comanda-bar-julio",
  "version": "1.0.0",
  "description": "Sistema de comanda digital — Bar do Júlio",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.bardojulio.comanda",
    "productName": "Comanda — Bar do Júlio",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    },
    "files": ["**/*", "!node_modules/.cache"],
    "extraResources": [
      { "from": "data/", "to": "data/", "filter": ["**/*"] }
    ]
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0"
  }
}